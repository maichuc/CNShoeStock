# Application environment
APP_ENV=local
APP_URL=http://localhost/QL_kho_giay

# Database
DB_HOST=localhost
DB_NAME=smart_shoes_warehouse2
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# AI API Keys Configuration (Để tăng độ chính xác nhận diện)
# Clarifai API (Miễn phí 5000 requests/tháng)
CLARIFAI_API_KEY=3cfb088834e84f2788301cf0ba5d64b3


# Azure Computer Vision (Miễn phí 5000 calls/tháng)  
# Đăng ký tại: https://azure.microsoft.com/services/cognitive-services/computer-vision/
# AZURE_COMPUTER_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_COMPUTER_VISION_KEY=your_azure_key_here


# HuggingFace API (Miễn phí)
# Đăng ký tại: https://huggingface.co/
# HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Mail (SMTP) - Gmail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME=Your Company Name

# ================================
# External Calendar API
# ================================

# Calendarific API - Holiday Calendar Service
# Đăng ký miễn phí tại: https://calendarific.com/
# Free tier: 1,000 requests/month
CALENDARIFIC_API_KEY=your-calendarific-api-key-here
CALENDARIFIC_COUNTRY=VN
CALENDARIFIC_CACHE_DAYS=30
MAIL_PASSWORD=your_app_password_here
MAIL_FROM_ADDRESS=cnshoestockcompany@gmail.com
MAIL_FROM_NAME="CN Shoes Stock Company - Smart Warehouse System"
MAIL_ENCRYPTION=tls

# Ximilar AI Configuration
XIMILAR_API_TOKEN=your_ximilar_token_here
XIMILAR_API_BASE_URL=https://api.ximilar.com/tagging/fashion/v2

# Hướng dẫn tạo App Password cho Gmail:
# 1. Đăng nhập Gmail và vào Google Account (myaccount.google.com)
# 2. Chọn Security > 2-Step Verification (bật nếu chưa có)
# 3. Chọn App passwords
# 4. Chọn app "Mail" và device "Other"
# 5. Nhập tên (ví dụ: "Smart Warehouse")
# 6. Google sẽ tạo App Password 16 ký tự
# 7. Copy password này và dán vào MAIL_PASSWORD (bỏ dấu cách)

# Hướng dẫn lấy Ximilar API Token:
# 1. Đăng ký tài khoản tại https://www.ximilar.com/
# 2. Tạo project mới cho Fashion Recognition
# 3. Copy API Token từ dashboard
# 4. Dán vào XIMILAR_API_TOKEN
